# ============================================
# SMTP 邮件服务配置
# ============================================
# 用于发送联系表单的邮件

# SMTP 服务器地址
# 常见服务商：
# - Gmail: smtp.gmail.com
# - Outlook/Hotmail: smtp-mail.outlook.com
# - QQ邮箱: smtp.qq.com
# - 163邮箱: smtp.163.com
# - 企业邮箱: 请联系您的邮箱服务商
SMTP_HOST=smtp.example.com

# SMTP 服务器端口
# - 25 (不加密)
# - 587 (TLS加密，推荐)
# - 465 (SSL加密)
SMTP_PORT=587

# SMTP 用户名（通常与发件邮箱相同）
SMTP_USER=your-email@example.com

# SMTP 密码（注意：对于 Gmail 等服务需要使用应用专用密码，不是登录密码）
# 获取方式：
# - Gmail: Google 账号 -> 安全 -> 应用专用密码
# - QQ邮箱: 设置 -> 账户 -> POP3/IMAP/SMTP/Exchange/CardDAV/CalDAV服务 -> 生成授权码
# - 163邮箱: 设置 -> POP3/SMTP/IMAP -> 开启服务 -> 获取授权码
SMTP_PASS=your-smtp-password-or-app-password

# 收件人邮箱地址（留空则使用 SMTP_USER 作为收件人）
# 如果希望发送到其他邮箱，请在此配置
RECIPIENT_EMAIL=your-recipient@example.com

# ============================================
# 飞书机器人配置
# ============================================
# 用于接收访客留言的实时通知

# 飞书自定义机器人 Webhook URL
# 获取方式：
# 1. 打开飞书群聊 -> 机器人管理 -> 添加机器人
# 2. 选择"自定义机器人"
# 3. 创建完成后，复制 Webhook URL
# 格式：https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 飞书机器人密钥（签名验证需要）⚠️ 重要：必须是 32 个字符！
# 获取方式：
# 1. 在飞书群聊中找到该机器人，点击"设置"或"Webhook 设置"
# 2. 进入"安全设置"
# 3. 勾选"签名校验"选项
# 4. 系统会自动生成一个 32 位的密钥
# 5. 使用"复制"按钮完整复制（必须是 32 个字符）
# 6. 粘贴到下方（不要有任何空格或换行）
#
# ⚠️ 如果密钥不是 32 个字符，说明复制不完整，需要重新复制！
# ⚠️ 正确示例：ONHtg1cudF3QKiJ8edyrceABCDEFGH（32字符）
# ❌ 错误示例：ONHtg1cudF3QKiJ8edyrce（21字符）
FEISHU_WEBHOOK_SECRET=your-32-character-secret-key-here

# 后台管理员配置
# ⚠️ 请在生产环境中修改默认密码！
NEXT_PUBLIC_ADMIN_USERNAME=admin
NEXT_PUBLIC_ADMIN_PASSWORD=admin123
