# ============================================
# SMTP 邮件服务配置
# ============================================
# 用于发送联系表单的邮件

# SMTP 服务器地址
# 常见服务商：
# - Gmail: smtp.gmail.com
# - Outlook/Hotmail: smtp-mail.outlook.com
# - QQ邮箱: smtp.qq.com
# - 163邮箱: smtp.163.com
# - 企业邮箱: 请联系您的邮箱服务商
SMTP_HOST=smtp.example.com

# SMTP 服务器端口
# - 25 (不加密)
# - 587 (TLS加密，推荐)
# - 465 (SSL加密)
SMTP_PORT=587

# SMTP 用户名（通常与发件邮箱相同）
SMTP_USER=your-email@example.com

# SMTP 密码（注意：对于 Gmail 等服务需要使用应用专用密码，不是登录密码）
# 获取方式：
# - Gmail: Google 账号 -> 安全 -> 应用专用密码
# - QQ邮箱: 设置 -> 账户 -> POP3/IMAP/SMTP/Exchange/CardDAV/CalDAV服务 -> 生成授权码
# - 163邮箱: 设置 -> POP3/SMTP/IMAP -> 开启服务 -> 获取授权码
SMTP_PASS=your-smtp-password-or-app-password

# 收件人邮箱地址（留空则使用 SMTP_USER 作为收件人）
# 如果希望发送到其他邮箱，请在此配置
RECIPIENT_EMAIL=your-recipient@example.com

# ============================================
# 飞书机器人配置
# ============================================
# 用于接收访客留言的实时通知

# 飞书自定义机器人 Webhook URL
# 获取方式：
# 1. 打开飞书开放平台：https://open.feishu.cn/
# 2. 创建自定义机器人（需要管理员权限）
# 3. 获取 Webhook URL（格式：https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxxxxx）
# 4. 获取机器人密钥（签名验证需要）
# 5. 将 Webhook URL 和密钥复制到下方
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxxxxx

# 飞书机器人密钥（签名验证需要）
# 获取方式：飞书群聊 -> 机器人设置 -> 查看密钥
# 如果不配置密钥，将使用无签名模式（可能失败）
FEISHU_WEBHOOK_SECRET=your-secret-key-here
